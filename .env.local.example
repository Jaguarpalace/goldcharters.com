# Supabase — get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — set to "true" to force live Supabase even in dev.
NEXT_PUBLIC_USE_SUPABASE=false

# Production site URL — used by sitemap, robots, canonical URLs, JSON-LD.
# In dev you can leave this unset; in production set it to your real domain.
NEXT_PUBLIC_SITE_URL=https://goldcharters.com

# Metal Price API (https://metalpriceapi.com) — SERVER ONLY.
# Used for the live gold ticker, calculator spot badge, auto-updating rates
# and the admin price dashboard. Never expose to the browser — no
# NEXT_PUBLIC_ prefix means Next.js will never bundle it into client code.
METAL_PRICE_API_KEY=your-metalpriceapi-key
